
# Database volume path. Change to a persistent location.
DATA_PATH=/tmp

# Database connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=db

# NIST NVD API rate limiting
NIST_MAX_RETRIES=5
NIST_RETRY_DELAY_SEC=10
NIST_REQUEST_DELAY_MS=600

# Ingestor logging
LOG_LEVEL=info
LOG_FORMAT=json
